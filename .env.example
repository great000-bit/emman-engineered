# Copy this file to .env and fill in real values. .env is gitignored and never committed.

# Formspree endpoint used by every form on the site (Contact, Professional Role
# application, Internship application). All three currently submit to the same form.
# Get this from your Formspree dashboard (https://formspree.io), pointed at
# creativeemmanlimited@gmail.com.
#
# NOTE: this is optional. If unset, the site falls back to the production endpoint
# already hardcoded in src/lib/formspree.ts, so missing this env var will NOT break
# form submissions in production — it's only useful for pointing local/dev builds at
# a different (e.g. test) Formspree form.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/xaqgwevv

# --- SEO / search engine verification ---------------------------------------------
# Optional. Leave blank until you've verified the site in each console — see SEO.md
# for setup steps. Both are safely ignored (meta tag omitted) when unset, so leaving
# these blank does not break anything.

# Google Search Console: Settings > Ownership verification > HTML tag method, copy
# just the "content" value (not the whole <meta> tag) into this variable.
VITE_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: same idea — copy just the "content" value from the meta-tag
# verification option.
VITE_BING_SITE_VERIFICATION=

# --- IndexNow (optional, future use) -----------------------------------------------
# IndexNow lets Bing/Yandex (and other participating engines) be notified the moment
# a page changes, instead of waiting for a crawl. Not wired up to anything yet — this
# is just the key placeholder for when that's implemented. See SEO.md.
VITE_INDEXNOW_KEY=
