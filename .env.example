# Copy this file to .env and fill in real values. .env is gitignored and never committed.

# Formspree endpoint used by every form on the site (Contact, Professional Role
# application, Internship application). All three currently submit to the same form.
# Get this from your Formspree dashboard (https://formspree.io), pointed at
# creativeemmanlimited@gmail.com.
#
# NOTE: this is optional. If unset, the site falls back to the production endpoint
# already hardcoded in src/lib/formspree.ts, so missing this env var will NOT break
# form submissions in production — it's only useful for pointing local/dev builds at
# a different (e.g. test) Formspree form.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/xaqgwevv
